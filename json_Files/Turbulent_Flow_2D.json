{
  "simulation_parameters": {
    "description": "2D Compressible Flow with Turbulence Models",
    "dimension": 2,
    "is_time_accurate": true,
    "max_iterations": 10000,
    "convergence_tolerance": 1e-6,
    "cfl_number": 0.5,
    "output_frequency": 100
  },
  
  "turbulence_model": {
    "model_type": "k_epsilon",
    "description": "Options: laminar, k_epsilon, k_omega_wilcox, k_omega_sst",
    "use_wall_functions": true,
    "y_plus_target": 30.0,
    "turbulence_intensity": 0.05,
    "turbulent_length_scale_ratio": 0.1,
    
    "k_epsilon_constants": {
      "C_mu": 0.09,
      "C_1": 1.44,
      "C_2": 1.92,
      "sigma_k": 1.0,
      "sigma_epsilon": 1.3
    },
    
    "k_omega_constants": {
      "beta_star": 0.09,
      "beta": 0.075,
      "sigma": 0.5,
      "sigma_star": 0.5,
      "alpha": 0.5556
    },
    
    "sst_constants": {
      "alpha_1": 0.5556,
      "beta_1": 0.075,
      "beta_star": 0.09,
      "sigma_k1": 0.85,
      "sigma_w1": 0.5,
      "alpha_2": 0.44,
      "beta_2": 0.0828,
      "sigma_k2": 1.0,
      "sigma_w2": 0.856,
      "a1": 0.31
    }
  },
  
  "flow_conditions": {
    "reference_conditions": {
      "pressure": 101325.0,
      "temperature": 288.15,
      "density": 1.225,
      "mach_number": 0.3,
      "reynolds_number": 1000000
    },
    
    "inlet_conditions": {
      "velocity_x": 100.0,
      "velocity_y": 0.0,
      "pressure": 101325.0,
      "temperature": 288.15,
      "turbulent_kinetic_energy": "auto",
      "turbulent_dissipation_rate": "auto",
      "specific_dissipation_rate": "auto"
    },
    
    "outlet_conditions": {
      "type": "pressure_outlet",
      "pressure": 101325.0,
      "turbulence_treatment": "zero_gradient"
    },
    
    "wall_conditions": {
      "type": "no_slip_wall",
      "temperature_type": "adiabatic",
      "wall_function_treatment": "automatic"
    },
    
    "symmetry_conditions": {
      "type": "symmetry",
      "turbulence_treatment": "zero_gradient"
    }
  },
  
  "grid_parameters": {
    "grid_file": "grid_files/cylinder_2d.msh",
    "characteristic_length": 1.0,
    "wall_distance_method": "exact"
  },
  
  "solver_parameters": {
    "spatial_discretization": {
      "convective_scheme": "roe",
      "gradient_method": "green_gauss",
      "limiter": "van_leer"
    },
    
    "temporal_discretization": {
      "time_integration": "runge_kutta_4",
      "turbulence_time_integration": "implicit"
    },
    
    "viscous_treatment": {
      "laminar_viscosity": "sutherland",
      "turbulent_viscosity": "turbulence_model",
      "effective_viscosity": "sum"
    }
  },
  
  "output_parameters": {
    "solution_file": "solution_turbulent.dat",
    "residual_file": "residuals_turbulent.dat",
    "turbulence_file": "turbulence_variables.dat",
    "vtk_output": true,
    "vtk_file": "results_turbulent.vtk",
    
    "monitor_variables": [
      "density",
      "velocity_x",
      "velocity_y",
      "pressure",
      "temperature",
      "turbulent_kinetic_energy",
      "turbulent_dissipation_rate",
      "specific_dissipation_rate",
      "turbulent_viscosity",
      "y_plus"
    ]
  },
  
  "validation_cases": {
    "flat_plate_boundary_layer": {
      "enabled": false,
      "reynolds_number": 5000000,
      "plate_length": 2.0,
      "expected_cf": 0.00332
    },
    
    "channel_flow": {
      "enabled": false,
      "reynolds_number": 10800,
      "channel_height": 2.0,
      "expected_cf": 0.00467
    },
    
    "backward_facing_step": {
      "enabled": false,
      "reynolds_number": 36000,
      "step_height": 1.0,
      "expected_reattachment_length": 6.28
    }
  },
  
  "advanced_settings": {
    "realizability_constraints": true,
    "production_limiters": true,
    "artificial_viscosity": false,
    "low_reynolds_corrections": false,
    "compressibility_corrections": true,
    "rotation_corrections": false
  }
}